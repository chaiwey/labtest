# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://labtest:labtest@localhost:5433/labtest?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-me"

# Resend (magic-link email). In dev the magic link is also logged to the console,
# so a real key is optional for local sign-in.
RESEND_API_KEY=""
EMAIL_FROM="LabTest <onboarding@resend.dev>"
